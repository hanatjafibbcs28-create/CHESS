t =int( input("Enter the no. of test cases:"))
for _ in range(t):
        a, b, c, d = map(int, input("Enter the values of a,b,c,d separated by space").split())
        if a < b:
            a += c 
        else:
            b += c  
        if a < b:
            a += d 
        else:
            b += d 
        if a >= b:
            print("N")
        else:
            print("S")
